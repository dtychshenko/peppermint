{
  "name": "peppermint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "docs:dev": "yarn --cwd docs start",
    "docs:build": "yarn --cwd docs build",
    "docs:serve": "yarn --cwd docs serve",
    "prepare": "husky install"
  },
  "dependencies": {
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": ">=6",
    "lint-staged": ">=10",
    "prettier": "^3.7.4",
    "typescript": "^5"
  }
}
