{
  "name": "peppermint",
  "version": "1.0.0",
  "description": "Spicy Personal Finance Dashboard App",
  "private": true,
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "author": "Dmitriy Tychshenko",
  "packageManager": "yarn@4.12.0",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "lint": "eslint --fix",
    "worker:run": "rw-scripts worker-run",
    "db:clean": "rm -rf .wrangler/state/v3/do/peppermint-Database",
    "clean": "rm -rf ./node_modules/.vite ./dist",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "release:staging": "CLOUDFLARE_ENV=staging yarn run release",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "types": "tsc",
    "docs:dev": "yarn --cwd docs start",
    "docs:release": "yarn --cwd docs deploy",
    "prepare": "husky",
    "format": "prettier --write"
  },
  "dependencies": {
    "@mantine/charts": "^8.3.12",
    "@mantine/core": "^8.3.12",
    "@mantine/dates": "^8.3.12",
    "@mantine/dropzone": "^8.3.12",
    "@mantine/hooks": "^8.3.12",
    "@mantine/notifications": "^8.3.12",
    "@tabler/icons-react": "^3.36.1",
    "ag-grid-react": "^35.0.0",
    "dayjs": "^1.11.19",
    "papaparse": "^5.5.3",
    "react": "^19.3.0-canary-4a3d993e-20260114",
    "react-dom": "^19.3.0-canary-4a3d993e-20260114",
    "react-server-dom-webpack": "^19.3.0-canary-4a3d993e-20260114",
    "react-virtuoso": "^4.18.1",
    "recharts": "^3.6.0",
    "rwsdk": "1.0.0-beta.48",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.20.1",
    "@types/node": "~24.10.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": ">=6",
    "lint-staged": ">=10",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.7.4",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "wrangler": "4.58.0"
  }
}
