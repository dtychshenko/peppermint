{
  "name": "peppermint",
  "version": "1.0.0",
  "description": "Spicy Personal Finance Dashboard App",
  "private": true,
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "author": "Dmitriy Tychshenko",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "rm -rf ./node_modules/.vite ./dist",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "release:staging": "CLOUDFLARE_ENV=staging yarn run release",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "types": "tsc",
    "docs:dev": "yarn --cwd docs start",
    "docs:release": "yarn --cwd docs deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.3.0-canary-4a3d993e-20260114",
    "react-dom": "^19.3.0-canary-4a3d993e-20260114",
    "react-server-dom-webpack": "^19.3.0-canary-4a3d993e-20260114",
    "rwsdk": "1.0.0-beta.48",
    "usehooks-ts": "^3.1.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.20.1",
    "@cloudflare/workers-types": "4.20260111.0",
    "@types/node": "~24.10.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": ">=6",
    "lint-staged": ">=10",
    "prettier": "^3.7.4",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "wrangler": "4.58.0"
  }
}
